local function getPing()
	local ok, ms = pcall(function() return LP:GetNetworkPing() * 1000 end)
	return (ok and ms) or 0
end

local function getM1D(model)
	local wv = model:FindFirstChild("Weapon")
	if not wv or wv.Value == "" then return nil end
	local wi = RepStore:FindFirstChild("WeaponINFO")
	if not wi then return nil end
	local winfo = wi:FindFirstChild(wv.Value)
	if not winfo then return nil end
	local m1d = winfo:FindFirstChild("M1Delay")
	return m1d and m1d.Value or nil
end

local function inRange(model)
	local mc = LP.Character
	if not mc then return false end
	local mr = root(mc)
	local er = root(model)
	if not mr or not er then return false end
	return (mr.Position - er.Position).Magnitude <= PARRY_DIST
end

local function doLegacy(model)
	if not S.ParryEnabled or not parryRemote then return end
	if isSelf(model) or not inRange(model) then return end
	if S.MissChance > 0 and math.random(1, 100) <= S.MissChance then return end
	local d = S.SkillParryDelay
	if S.AdjustToPing then d = math.max(0, d - getPing() / 1000) end
	if S.PanicChance > 0 and math.random(1, 100) <= S.PanicChance then
		d = math.max(0, d - math.random(80, 180) / 1000)
	end
	if d > 0 then task.wait(d) end
	if not inRange(model) then return end
	pcall(function() parryRemote:FireServer() end)
end

local function doRevamped(delay, model)
	if not S.ParryEnabled or not parryRemote then return end
	if parryFired[model] then return end
	if isSelf(model) or not inRange(model) then return end
	if S.MissChance > 0 and math.random(1, 100) <= S.MissChance then return end
	parryFired[model] = true
	local d = math.max(0, delay)
	if S.AdjustToPing then d = math.max(0, d - (getPing() / 1000) * 2) end
	if S.PanicChance > 0 and math.random(1, 100) <= S.PanicChance then
		d = math.max(0, d - math.random(80, 180) / 1000)
	end
	if d > 0 then task.wait(d) end
	if not inRange(model) then parryFired[model] = nil; return end
	pcall(function() parryRemote:FireServer() end)
end

local function hookable(model)
	if not model or not model:IsA("Model") then return false end
	if isSelf(model) then return false end
	return model:FindFirstChild("Humanoid") ~= nil
end

local function hookParry(model)
	if not hookable(model) then return end
	if parryCons[model] then return end

	local conns = {}

	local function onAttack(sigName, sigObj)
		if not S.ParryEnabled then return end
		if isSelf(model) or not inRange(model) then return end
		if isPlr(model) and not S.ParryTargetPlayers then return end

		local isM1 = sigName == "StartedAnAttack" or sigName == "LightAttack"
		local isSkill = sigName == "UsingMove"
		local isParryable = sigName == "StartedAnAttack"

		if S.ParryDetection == "M1 Only" and not isM1 then return end
		if S.ParryDetection == "Parryable Only" and not isParryable then return end
		if not isM1 and not isSkill then return end
		if model:FindFirstChild("PerfectParry") or model:FindFirstChild("HitParry") then return end

		task.spawn(showParryInd, model, isSkill)

		if S.ParryMode == "Legacy" then
			task.spawn(doLegacy, model)
			if sigObj then
				sigObj.AncestryChanged:Connect(function()
					if not sigObj:IsDescendantOf(model) then hideParryInd(model) end
				end)
			end
		else
			local delay = isSkill and 0.3 or (function()
				local m1d = getM1D(model)
				return m1d and (m1d >= 0.9 and math.max(0.05, m1d - 0.15) or m1d >= 0.65 and math.max(0.05, m1d - 0.25) or m1d / 2) or 0.15
			end)()
			task.spawn(doRevamped, delay, model)
			if sigObj then
				sigObj.AncestryChanged:Connect(function()
					if not sigObj:IsDescendantOf(model) then
						parryFired[model] = nil
						hideParryInd(model)
					end
				end)
			end
		end
	end

	table.insert(conns, model.ChildAdded:Connect(function(child) onAttack(child.Name, child) end))

	for _, sig in ipairs(ATK_SIGS) do
		local ex = model:FindFirstChild(sig)
		if ex and ex:IsA("BoolValue") then
			local last = ex.Value
			if last then task.spawn(onAttack, sig, ex) end
			table.insert(conns, ex:GetPropertyChangedSignal("Value"):Connect(function()
				if ex.Value and not last then
					last = true
					onAttack(sig, ex)
				elseif not ex.Value then
					last = false
					if S.ParryMode == "Revamped" then parryFired[model] = nil end
					hideParryInd(model)
				end
			end))
		elseif ex then
			task.spawn(onAttack, sig, ex)
		end
	end

	table.insert(conns, model.AncestryChanged:Connect(function()
		if not model:IsDescendantOf(Workspace) then
			for _, c in ipairs(conns) do pcall(c.Disconnect, c) end
			parryCons[model] = nil
			parryFired[model] = nil
		end
	end))

	parryCons[model] = conns
end

local function setupParry()
	if not parryRemote then warn("[Archivist] ParryActivate not found"); return end
	local al = alive()
	if not al then return end

	for _, model in ipairs(al:GetChildren()) do
		task.wait(0.02)
		if not isSelf(model) then task.spawn(hookParry, model) end
	end
	al.ChildAdded:Connect(function(model)
		task.wait(0.2)
		if not isSelf(model) then task.spawn(hookParry, model) end
	end)

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr == LP then continue end
		if plr.Character then task.spawn(hookParry, plr.Character) end
		plr.CharacterAdded:Connect(function(c) task.wait(0.2); task.spawn(hookParry, c) end)
	end
	Players.PlayerAdded:Connect(function(plr)
		if plr == LP then return end
		plr.CharacterAdded:Connect(function(c) task.wait(0.2); task.spawn(hookParry, c) end)
	end)
end

task.defer(setupParry)

