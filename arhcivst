local atpBusy = false
local atpSavedCF = nil
local atpCircle = Drawing.new("Circle")
atpCircle.Visible = false
atpCircle.Radius = S.AttackTeleportFOV
atpCircle.Color = Color3.fromRGB(255, 165, 0)
atpCircle.Thickness = 2
atpCircle.Filled = false
atpCircle.NumSides = 64

local function atpFind()
	local al = alive()
	if not al then return nil end
	local mp = UIS:GetMouseLocation()
	local best, bestD = nil, S.AttackTeleportFOV
	for _, obj in ipairs(al:GetChildren()) do
		if isSelf(obj) or not validTarget(obj, true) then continue end
		local r = root(obj)
		if r then
			local sp, on = Camera:WorldToViewportPoint(r.Position)
			if on then
				local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
				if d < bestD then bestD = d; best = r end
			end
		end
	end
	return best
