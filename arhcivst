-- Main Loops
local prevLk = {}
local prevAtp = {}
local noclipT = 0
local buffT = 0
local fallT = 0
local stamT = 0
local espT = 0
local ESP_R = 0.05
local NOCLIP_R = 0.05
local BUFF_R = 0.1
local FALL_R = 0.2
local STAM_R = 0.1

RS.RenderStepped:Connect(function()
	do
		local show = S.LockonShowFOV and S.LockonEnabled
		if show ~= prevLk.visible or (show and (S.LockonFOV ~= prevLk.radius or lkLocked ~= prevLk.locked)) then
			prevLk.visible = show
			prevLk.radius = S.LockonFOV
			prevLk.locked = lkLocked
			lkCircle.Visible = show
			lkCircle.Radius = S.LockonFOV
			lkCircle.Color = lkLocked and Color3.new(1, 0, 0) or Color3.new(1, 1, 1)
		end
		if show then
			lkCircle.Position = S.LockonMode == "Cursor" and UIS:GetMouseLocation() or Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
		end
	end
	do
		local show = S.AttackTeleportEnabled
		if show ~= prevAtp.visible or (show and S.AttackTeleportFOV ~= prevAtp.radius) then
			prevAtp.visible = show
			prevAtp.radius = S.AttackTeleportFOV
			atpCircle.Visible = show
			atpCircle.Radius = S.AttackTeleportFOV
		end
		if show then atpCircle.Position = UIS:GetMouseLocation() end
	end

	if S.LockonEnabled then
		if S.LockonAuto and not lkLocked then
			local t = lkFindTarget()
			if t then
				lkTarget = t
				lkPart = lkGetPart(t)
				lkLocked = true
			end
		end
		if lkLocked and lkTarget and lkPart and lkPart.Parent then
			if not validLk(lkTarget) then
				lkLocked = false
				lkTarget = nil
				lkPart = nil
			else
				lkPart = lkGetPart(lkTarget)
				if lkPart then
					local tp = lkPart.Position
					local cp = Camera.CFrame.Position
					if S.LockonStrength >= 100 then
						local tcf = CFrame.lookAt(cp, tp)
						Camera.CFrame = S.LockonSmooth and Camera.CFrame:Lerp(tcf, S.LockonSmoothness) or tcf
					elseif S.LockonStrength > 0 then
						local ml = Camera.CFrame.LookVector:Lerp((tp - cp).Unit, S.LockonStrength / 100)
						Camera.CFrame = CFrame.lookAt(cp, cp + ml)
					end
				else
					lkLocked = false
					lkTarget = nil
				end
			end
		elseif lkLocked then
			lkLocked = false
			lkTarget = nil
			lkPart = nil
		end
	end
end)

RS.Heartbeat:Connect(function(dt)
	tickAnimSpeed(dt)

	if S.ParryMoveEnabled then
		local c = LP.Character
		if c then
			local h = c:FindFirstChild("Humanoid")
			if h and c:FindFirstChild("UsingMove") then h.WalkSpeed = 16 end
		end
	end

	espT = espT + dt
	if espT >= ESP_R then
		espT = 0
		getESPColors()
		if S.ESPEnabled then
			local lc = LP.Character
			local lr = lc and root(lc)
			local al = alive()
			if lr and al then
				local cur = {}
				for _, obj in ipairs(al:GetChildren()) do
					if not obj:IsA("Model") then continue end
					local h = obj:FindFirstChild("Humanoid")
					if not h or h.Health <= 0 then continue end
					local r = root(obj)
					if not r then continue end
					local dist = (r.Position - lr.Position).Magnitude
					if dist > S.ESPMaxDist then continue end
					local ip   = espPlrCache[obj] == true
					local boss = obj:FindFirstChild("BossEnemy") ~= nil
					makeESP(obj, ip, boss)
					cur[obj] = true
					local d = espObjs[obj]
					if d then drawESP(obj, d, h, dist) end
				end
				for model in pairs(espObjs) do
					if not cur[model] then killESP(model) end
				end
			end
		else
			for model in pairs(espObjs) do killESP(model) end
		end
	end
	if S.NoFallEnabled then
		fallT = fallT + dt
		if fallT >= FALL_R then
			fallT = 0
			noFallTick()
		end
	end
	if S.NoStaminaEnabled then
		stamT = stamT + dt
		if stamT >= STAM_R then
			stamT = 0
			noStamTick()
		end
	end
	if S.HasteEnabled or S.WarpDashEnabled then
		buffT = buffT + dt
		if buffT >= BUFF_R then
			buffT = 0
			hasteTick()
			warpTick()
		end
	end

	if S.AttachEnabled and attachActive and noclipOn then
		noclipT = noclipT + dt
		if noclipT >= NOCLIP_R then
			noclipT = 0
			for _, p in ipairs(charParts) do
				if p and p.Parent then p.CanCollide = false end
			end
		end
	end

	if S.AutoFarmEnabled and farmAttached and farmNoclipOn then
		for _, p in ipairs(farmParts) do
			if p and p.Parent then p.CanCollide = false end
		end
	end

	if S.AttachEnabled and attachActive then
		local mc = LP.Character
		if not mc then
			attachActive = false
			return
		end
		local mr = root(mc)
		if not mr then return end
		if mr.AssemblyLinearVelocity.Magnitude > 50 then mr.AssemblyLinearVelocity = Vector3.zero end
		if not flyOn then attachStartFly() end
		if not noclipOn then attachStartNoclip() end
		local enemy = attachTarget
		if enemy then
			local h = enemy:FindFirstChild("Humanoid")
			if not h or h.Health <= 1 then
				if root(enemy) then lastEnemyPos = root(enemy).Position end
				attachStop()
				return
			end
		end
		if not enemy or not enemy.Parent or not root(enemy) then
			enemy = attachClosest()
			if enemy then
				attachTarget = enemy
			else
				attachStop()
				return
			end
		else
			local er = root(enemy)
			if er and (mr.Position - er.Position).Magnitude > S.AttachRange then
				enemy = attachClosest()
				if enemy then
					attachTarget = enemy
				else
					attachStop()
					return
				end
			end
		end
		local er = root(enemy)
		if not er then return end
		lastEnemyPos = er.Position
		local tp = attachPos(enemy)
		if not tp then return end
		mr.CFrame = CFrame.lookAt(tp, er.Position)
		mr.AssemblyLinearVelocity = Vector3.zero
		local hum = mc:FindFirstChild("Humanoid")
		if hum then hum.AutoRotate = false end
	else
		if flyOn then attachKillFly() end
		if noclipOn then attachKillNoclip() end
	end

	if S.AutoFarmEnabled and farmAttached and farmTarget then
		local mc = LP.Character
		if not mc then return end
		local mr = root(mc)
		local tr = root(farmTarget)
		if not mr then return end
		if not tr then
			farmDetach()
			farmScan(true)
			return
		end
		if not farmFlyOn then farmStartFly() end
		if not farmNoclipOn then farmStartNoclip() end
		local lv = tr.CFrame.LookVector
		local dir = S.FarmForward <= 1 and -lv * (1 - S.FarmForward) or lv * (S.FarmForward - 1)
		mr.CFrame = CFrame.lookAt(tr.Position + dir * S.FarmDistance + Vector3.new(0, S.FarmHeight, 0), tr.Position)
		mr.AssemblyLinearVelocity = Vector3.zero
	else
		if farmFlyOn then farmKillFly() end
		if farmNoclipOn then farmKillNoclip() end
	end
end)

