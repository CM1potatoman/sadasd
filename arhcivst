-- Config System
local CFG_FOLDER = "ArchivistPresets"
local PLACE_ID = 99831550635699

if not isfolder(CFG_FOLDER) then makefolder(CFG_FOLDER) end

local function getConfigList()
	local files = listfiles(CFG_FOLDER)
	local names = {}
	for _, f in ipairs(files) do
		local n = f:match("([^/\\]+)%.json$")
		if n then names[#names+1] = n end
	end
	if #names == 0 then names = {"Default"} end
	return names
end

local function saveConfig(name)
	if not name or name == "" then return false end
	local ok = pcall(function() writefile(CFG_FOLDER.."/"..name..".json", HttpService:JSONEncode(S)) end)
	return ok
end

local function loadConfig(name)
	if not name or name == "" then return false end
	local path = CFG_FOLDER.."/"..name..".json"
	if not isfile(path) then return false end
	local ok, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
	if not ok or not data then return false end
	for k, v in pairs(data) do if S[k] ~= nil then S[k] = v end end
	return true
end

local function deleteConfig(name)
	if not name or name == "" then return false end
	local path = CFG_FOLDER.."/"..name..".json"
	if not isfile(path) then return false end
	pcall(function() delfile(path) end)
	return true
end

-- Helper Functions
local function root(c)
	if not c then return nil end
	return c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso") or c:FindFirstChild("UpperTorso")
end

local function isPlr(c)
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Character == c then return true end
	end
	return false
end

local function isSelf(m) return m == LP.Character end

local function validTarget(m, allowPlrs)
	if not m or not m:IsA("Model") then return false end
	if isSelf(m) then return false end
	local h = m:FindFirstChild("Humanoid")
	if not h or h.Health <= 0 then return false end
	if isPlr(m) and not allowPlrs then return false end
	return true
end

local function alive() return Workspace:FindFirstChild("Alive") end

-- Hitbox System
local origSizes = {}
local function applyHitbox(npc)
	if not S.HitboxEnabled then return end
	local r = root(npc)
	if r and r:IsA("BasePart") then
		if not origSizes[r] then origSizes[r] = r.Size end
		r.Size = Vector3.new(S.HitboxSize, S.HitboxSize, S.HitboxSize)
		r.Transparency = S.HitboxTrans
		r.CanCollide = false
	end
end

local function applyHitboxAll()
	local al = alive()
	if not al then return end
	for _, npc in ipairs(al:GetChildren()) do
		if not isPlr(npc) and npc:IsA("Model") then applyHitbox(npc) end
	end
end

local function revertHitboxAll()
	for r, sz in pairs(origSizes) do
		if r and r.Parent then r.Size = sz; r.Transparency = 0 end
	end
	origSizes = {}
end

-- Weapon Modifier
local weapInfo = RepStore:FindFirstChild("WeaponINFO")
local weapOrig = {}

local function saveWeapDefaults()
	if not weapInfo then return end
	for _, w in ipairs(weapInfo:GetChildren()) do
		weapOrig[w.Name] = {}
		local m = w:FindFirstChild("M1Delay")
		if m then weapOrig[w.Name].M1Delay = m.Value end
		local sw = w:FindFirstChild("SwingSpeed")
		if sw then weapOrig[w.Name].SwingSpeed = sw.Value end
	end
end

local function applyWeap()
	if not weapInfo or not S.WeaponEnabled then return end
	for _, w in ipairs(weapInfo:GetChildren()) do
		local m = w:FindFirstChild("M1Delay")
		if m then m.Value = S.M1Speed end
		local sw = w:FindFirstChild("SwingSpeed")
		if sw then sw.Value = S.SwingSpeed end
	end
end

local function revertWeap()
	if not weapInfo then return end
	for _, w in ipairs(weapInfo:GetChildren()) do
		local ov = weapOrig[w.Name]
		if ov then
			local m = w:FindFirstChild("M1Delay")
			if m and ov.M1Delay then m.Value = ov.M1Delay end
			local sw = w:FindFirstChild("SwingSpeed")
			if sw and ov.SwingSpeed then sw.Value = ov.SwingSpeed end
		end
	end
end

if weapInfo then task.defer(saveWeapDefaults) end

-- Animation Speed
local animT = 0
local function tickAnimSpeed(dt)
	if not S.AnimEnabled then return end
	animT = animT + dt
	if animT < 0.1 then return end
	animT = 0
	local c = LP.Character
	if not c then return end
	local h = c:FindFirstChildOfClass("Humanoid") or c:FindFirstChildOfClass("AnimationController")
	if not h then return end
	for _, t in ipairs(h:GetPlayingAnimationTracks()) do pcall(t.AdjustSpeed, t, S.AnimSpeed) end
end

-- No Ragdoll
local ragTags = {"Ragdolled", "Ragdoll", "IsRagdoll", "KnockedDown", "Stunned", "DashDisabled", "CanRagdoll", "Ragdolling"}

local function hookNoRag(c)
	if not c then return end
	c.ChildAdded:Connect(function(child)
		if not S.NoRagdollEnabled then return end
		for _, n in ipairs(ragTags) do
			if child.Name == n then
				if child:IsA("BoolValue") then child.Value = false
				elseif child:IsA("StringValue") or child:IsA("ObjectValue") then child:Destroy() end
				break
			end
		end
	end)
	for _, n in ipairs(ragTags) do
		local t = c:FindFirstChild(n)
		if t and t:IsA("BoolValue") then
			t:GetPropertyChangedSignal("Value"):Connect(function()
				if S.NoRagdollEnabled and t.Value then t.Value = false end
			end)
		end
	end
	local hum = c:FindFirstChild("Humanoid")
	if hum then
		hum.StateChanged:Connect(function(_, ns)
			if not S.NoRagdollEnabled then return end
			if ns == Enum.HumanoidStateType.Ragdoll or ns == Enum.HumanoidStateType.FallingDown
				or ns == Enum.HumanoidStateType.GettingUp or ns == Enum.HumanoidStateType.Physics then
				hum:ChangeState(Enum.HumanoidStateType.Running)
			end
		end)
	end
end

