local function atpFire(isCrit)
	if not S.AttackTeleportEnabled or atpBusy then return end
	local c = LP.Character
	if not c then return end
	local r = root(c)
	if not r then return end
	local target = atpFind()
	if not target then return end
	local aD = isCrit and S.AttackTeleportCritDelay or S.AttackTeleportM1Delay
	local rD = isCrit and S.AttackTeleportCritReturn or S.AttackTeleportM1Return
	atpBusy = true
	atpSavedCF = r.CFrame
	local tv = target.Position
	local rv = target.CFrame.RightVector
	local lv = target.CFrame.LookVector
	local side = math.random(1, 3)
	r.CFrame = CFrame.lookAt(tv + (side == 1 and -rv * 3 or side == 2 and rv * 3 or -lv * 3), tv)
	task.wait(aD + rD)
	if atpSavedCF then r.CFrame = atpSavedCF end
	atpBusy = false
end

