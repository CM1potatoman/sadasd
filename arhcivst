-- Fly / Noclip Helpers
local function startFly(r, hum, parts)
	local bg = Instance.new("BodyGyro")
	bg.P = 9e4
	bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
	bg.CFrame = r.CFrame
	bg.Parent = r
	parts[#parts+1] = bg
	local bv = Instance.new("BodyVelocity")
	bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
	bv.Velocity = Vector3.zero
	bv.Parent = r
	parts[#parts+1] = bv
	hum.PlatformStand = true
end

local function stopFly(parts, c)
	for _, p in ipairs(parts) do pcall(p.Destroy, p) end
	table.clear(parts)
	if c then
		local h = c:FindFirstChild("Humanoid")
		if h then h.PlatformStand = false end
	end
end

-- Attach System
local char = LP.Character or LP.CharacterAdded:Wait()
local charParts = {}
local attachTarget, attachActive = nil, false
local flyOn, noclipOn = false, false
local flyParts = {}
local lastEnemyPos = nil

local function rebuildCharParts(c)
	charParts = {}
	if not c then return end
	for _, v in ipairs(c:GetDescendants()) do
		if v:IsA("BasePart") then charParts[#charParts+1] = v end
	end
end
rebuildCharParts(char)

local function attachKillFly()
	if not flyOn then return end
	stopFly(flyParts, LP.Character)
	flyOn = false
end

local function attachStartFly()
	if flyOn then return end
	local c = LP.Character
	if not c then return end
	local r = root(c)
	local h = c:FindFirstChild("Humanoid")
	if not r or not h then return end
	startFly(r, h, flyParts)
	flyOn = true
end

local function attachStartNoclip() noclipOn = true end

local function attachKillNoclip()
	if not noclipOn then return end
	noclipOn = false
	for _, p in ipairs(charParts) do if p and p.Parent then p.CanCollide = true end end
end

local function attachSafeTP()
	local c = LP.Character
	if not c then return end
	local r = root(c)
	if not r then return end
	local tp = lastEnemyPos and (lastEnemyPos + Vector3.new(0, 5, 0)) or (r.Position + Vector3.new(0, 5, 0))
	r.CFrame = CFrame.new(tp)
end

local function attachStop()
	if not attachActive then return end
	attachActive = false
	attachTarget = nil
	attachKillFly()
	attachKillNoclip()
	attachSafeTP()
	local c = LP.Character
	if c then
		local h = c:FindFirstChild("Humanoid")
		if h then h.AutoRotate = true end
	end
end

local function attachPos(enemy)
	local er = root(enemy)
	if not er then return nil end
	local lv = er.CFrame.LookVector
	local dir = S.AttachForward <= 1 and -lv * (1 - S.AttachForward) or lv * (S.AttachForward - 1)
	return er.Position + dir * S.AttachDistance + Vector3.new(0, S.AttachHeight, 0), lv
end

local function attachClosest()
	local c = LP.Character
	if not c then return nil end
	local r = root(c)
	if not r then return nil end
	local al = alive()
	if not al then return nil end
	local best, bestD = nil, math.huge
	for _, t in ipairs(al:GetChildren()) do
		if validTarget(t, S.AttachTargetPlayers) then
			local tr = root(t)
			if tr then
				local d = (r.Position - tr.Position).Magnitude
				if d <= S.AttachRange and d < bestD then
					bestD = d
					best = t
					lastEnemyPos = tr.Position
				end
			end
		end
	end
	return best
end


-- Auto Farm System
local farmTarget, farmAttached = nil, false
local farmFlyOn, farmNoclipOn = false, false
local farmFlyParts = {}
local farmBossTarget = nil
local farmDone = false
local farmDmgTime = 0
local farmFinTime = 0
local farmM1Time = 0
local farmScanTime = 0
local farmScanCache = nil
local farmSkillIdx = 1
local farmSkillRot = {3, 2, 1, 4}
local farmSkillTime = 0
local farmParts = {}
local farmKeys = {[1] = Enum.KeyCode.One, [2] = Enum.KeyCode.Two, [3] = Enum.KeyCode.Three, [4] = Enum.KeyCode.R}

local function farmRebuild()
	farmParts = {}
	local c = LP.Character
	if not c then return end
	for _, v in ipairs(c:GetDescendants()) do
		if v:IsA("BasePart") then farmParts[#farmParts+1] = v end
	end
end

local function farmStartFly()
	if farmFlyOn then return end
	local c = LP.Character
	if not c then return end
	local r = root(c)
	local h = c:FindFirstChild("Humanoid")
	if not r or not h then return end
	startFly(r, h, farmFlyParts)
	farmFlyOn = true
end

local function farmKillFly()
	if not farmFlyOn then return end
	stopFly(farmFlyParts, LP.Character)
	farmFlyOn = false
end

local function farmStartNoclip() farmNoclipOn = true end

local function farmKillNoclip()
	if not farmNoclipOn then return end
	farmNoclipOn = false
	for _, p in ipairs(farmParts) do if p and p.Parent then p.CanCollide = true end end
end

local function farmDetach()
	farmAttached = false
	farmTarget = nil
	farmKillFly()
	farmKillNoclip()
end

local function farmFindBoss()
	if not S.FarmPrioritizeBoss then return nil end
	local al = alive()
	if not al then return nil end
	local c = LP.Character
	local r = c and root(c)
	local best, bestD = nil, S.FarmDetectionRange
	for _, obj in ipairs(al:GetChildren()) do
		if obj:IsA("Model") and obj ~= c then
			if not validTarget(obj, S.FarmTargetPlayers) then continue end
			local h = obj:FindFirstChild("Humanoid")
			if h and h.Health > 0 and obj:FindFirstChild("BossEnemy") then
				if r then
					local or2 = root(obj)
					if or2 then
						local d = (r.Position - or2.Position).Magnitude
						if d <= S.FarmDetectionRange and d < bestD then
							bestD = d
							best = obj
						end
					end
				else
					best = obj
				end
			end
		end
	end
	return best
end

local function farmFindEnemy()
	local c = LP.Character
	if not c then return nil end
	local r = root(c)
	if not r then return nil end
	local al = alive()
	if not al then return nil end
	local best, bestD = nil, S.FarmDetectionRange
	for _, obj in ipairs(al:GetChildren()) do
		if obj:IsA("Model") and obj ~= c then
			if not validTarget(obj, S.FarmTargetPlayers) then continue end
			local h = obj:FindFirstChild("Humanoid")
			if h and h.Health > 0 then
				local or2 = root(obj)
				if or2 then
					local d = (r.Position - or2.Position).Magnitude
					if d <= S.FarmDetectionRange and d < bestD then
						bestD = d
						best = obj
					end
				end
			end
		end
	end
	return best
end

local function farmScan(force)
	local now = tick()
	local stale = not farmScanCache or not farmScanCache.Parent
		or not farmScanCache:FindFirstChild("Humanoid")
		or farmScanCache.Humanoid.Health <= 1
	if force or stale or (now - farmScanTime >= S.FarmScanCooldown) then
		farmScanTime = now
		farmScanCache = farmFindBoss() or farmFindEnemy()
	end
	return farmScanCache
end

local function farmLatch(target)
	if not target then return false end
	local c = LP.Character
	if not c then return false end
	local r = root(c)
	local tr = root(target)
	if not r or not tr then return false end
	local lv = tr.CFrame.LookVector
	local dir = S.FarmForward <= 1 and -lv * (1 - S.FarmForward) or lv * (S.FarmForward - 1)
	r.CFrame = CFrame.lookAt(tr.Position + dir * S.FarmDistance + Vector3.new(0, S.FarmHeight, 0), tr.Position)
	r.AssemblyLinearVelocity = Vector3.zero
	farmTarget = target
	farmAttached = true
	return true
end

local function farmHit(slot)
	pcall(function()
		VIM:SendKeyEvent(true, farmKeys[slot], false, game)
		task.wait(0.05)
		VIM:SendKeyEvent(false, farmKeys[slot], false, game)
	end)
end

local function farmM1()
	pcall(function()
		VIM:SendMouseButtonEvent(0, 0, 0, true, game, 1)
		task.wait(0.02)
		VIM:SendMouseButtonEvent(0, 0, 0, false, game, 1)
	end)
	farmM1Time = tick()
end

local function farmFinish()
	pcall(function()
		VIM:SendKeyEvent(true, Enum.KeyCode.LeftControl, false, game)
		task.wait(0.05)
		VIM:SendMouseButtonEvent(0, 0, 0, true, game, 1)
		task.wait(0.02)
		VIM:SendMouseButtonEvent(0, 0, 0, false, game, 1)
		VIM:SendKeyEvent(false, Enum.KeyCode.LeftControl, false, game)
	end)
	farmFinTime = tick()
end

local function farmLoop()
	task.wait(0.1)
	while S.AutoFarmEnabled and not farmDone do
		local target = farmScan()
		if not target then task.wait(2); continue end

		local hp = target.Humanoid and target.Humanoid.Health or 0
		if hp <= 1 then
			farmDetach()
			farmScanCache = nil
			farmScanTime = 0
			task.wait(1)
			continue
		end

		if target:FindFirstChild("BossEnemy") then farmBossTarget = target end
		if farmBossTarget then
			local bh = farmBossTarget:FindFirstChild("Humanoid")
			if bh and bh.Health <= 0 then
				farmDone = true
				farmDetach()
				break
			end
		end

		if not farmAttached or farmTarget ~= target then
			farmDetach()
			task.wait(0.2)
			farmLatch(target)
			task.wait(0.2)
			farmDmgTime = tick()
			continue
		end

		if farmAttached and (tick() - farmDmgTime) > S.FarmRecheckDelay then
			farmDetach()
			task.wait(0.3)
			farmLatch(target)
			task.wait(0.2)
			farmDmgTime = tick()
			continue
		end

		hp = farmTarget and farmTarget.Humanoid and farmTarget.Humanoid.Health or 0
		if hp < S.FarmFinisherHPThreshold and hp > 1 then
			if (tick() - farmFinTime) > S.FarmFinisherInterval then
				farmFinish()
				farmDmgTime = tick()
			end
			task.wait(0.1)
			continue
		end

		if (tick() - farmM1Time) >= S.FarmM1Interval then
			farmM1()
			farmDmgTime = tick()
		end

		if (tick() - farmDmgTime) % 2 < 0.1 then
			farmHit(farmSkillRot[farmSkillIdx])
			farmSkillIdx = (farmSkillIdx % #farmSkillRot) + 1
		end

		task.wait(0.05)
	end
	farmDetach()
	S.AutoFarmEnabled = false
	farmDone = false
end

-- Lock-On System
local lkTarget, lkPart = nil, nil
local lkLocked = false
local lkCircle = Drawing.new("Circle")
lkCircle.Visible = false
lkCircle.Radius = S.LockonFOV
lkCircle.Color = Color3.new(1, 1, 1)
lkCircle.Thickness = 1
lkCircle.Filled = false
lkCircle.NumSides = 64

local function validLk(obj)
	if not obj or not obj:IsA("Model") or isSelf(obj) then return false end
	local h = obj:FindFirstChild("Humanoid")
	if not h or h.Health <= 0 then return false end
	local ip = isPlr(obj)
	if S.LockonFilter == "NPCs Only" and ip then return false end
	if S.LockonFilter == "Players Only" and not ip then return false end
	return true
end

local function lkGetPart(obj)
	if not obj then return nil end
	if S.LockonPart == "Head" then return obj:FindFirstChild("Head") or root(obj) end
	if S.LockonPart == "Torso" then return obj:FindFirstChild("Torso") or obj:FindFirstChild("UpperTorso") or root(obj) end
	return root(obj)
end

local function lkFindTarget()
	local al = alive()
	if not al then return nil end
	local isCam = S.LockonMode == "Camera"
	local isDist = S.LockonMode == "Distance"
	local mouse = not isCam and not isDist and UIS:GetMouseLocation()
	local center = isCam and Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	local myRoot = isDist and root(LP.Character)
	local best, bestD = nil, isDist and math.huge or S.LockonFOV
	for _, obj in ipairs(al:GetChildren()) do
		if not validLk(obj) then continue end
		local part = lkGetPart(obj)
		if not part then continue end
		if isDist then
			if not myRoot then continue end
			local d = (myRoot.Position - part.Position).Magnitude
			if d < bestD then bestD = d; best = obj end
		else
			local sp, on = Camera:WorldToViewportPoint(part.Position)
			if not on then continue end
			local ref = isCam and center or mouse
			local d = (Vector2.new(sp.X, sp.Y) - ref).Magnitude
			if d <= S.LockonFOV and d < bestD then bestD = d; best = obj end
		end
	end
	return best
end

local function toggleLk()
	if lkLocked then
		lkLocked = false
		lkTarget = nil
		lkPart = nil
	else
		lkTarget = lkFindTarget()
		if lkTarget then
			lkPart = lkGetPart(lkTarget)
			lkLocked = true
		end
	end
end

