}
local SKEL_N = #SKEL

local espObjs    = {}
local espPlrCache = {}

-- ── Color cache — parse once, reuse forever ──────────
-- Avoids string.match pattern parsing every frame
local _colorCache = {}
local function c3FromStr(str)
    if _colorCache[str] then return _colorCache[str] end
    local r, g, b = str:match("(%d+),(%d+),(%d+)")
    local c = r and Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b)) or Color3.new(1,0,0)
    _colorCache[str] = c
    return c
end

-- Cached color values — rebuilt only when S color strings change
local _cachedBossCol  = nil
local _cachedPlrCol   = nil
local _cachedNPCCol   = nil
local _lastBossStr    = ""
local _lastPlrStr     = ""
local _lastNPCStr     = ""

local function getESPColors()
    if S.ESPBossColor   ~= _lastBossStr then _lastBossStr = S.ESPBossColor;  _cachedBossCol = c3FromStr(S.ESPBossColor) end
    if S.ESPPlayerColor ~= _lastPlrStr  then _lastPlrStr  = S.ESPPlayerColor; _cachedPlrCol  = c3FromStr(S.ESPPlayerColor) end
    if S.ESPNPCColor    ~= _lastNPCStr  then _lastNPCStr  = S.ESPNPCColor;   _cachedNPCCol  = c3FromStr(S.ESPNPCColor) end
end

local function espColor(isBoss, isPlr2)
    if isBoss  then return _cachedBossCol end
    if isPlr2  then return _cachedPlrCol  end
    return _cachedNPCCol
end

-- ── Drawing factory ──────────────────────────────────
local function newD(t, props)
    local d = Drawing.new(t)
    for k, v in pairs(props) do d[k] = v end
    return d
end

-- ── Player lookup — O(1) via cache ───────────────────
local function playerFromModel(model)
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character == model then return p end
    end
end

-- ── Item check — set lookup, no iteration ────────────
local function getHeldItems(player)
    local found = {}
    if not player then return found end
    local bp = player:FindFirstChild("Backpack")
    if bp then
        for _, item in ipairs(bp:GetChildren()) do
            if TARGET_ITEM_SET[item.Name] then found[#found+1] = item.Name end
        end
    end
    local tool = player.Character and player.Character:FindFirstChildOfClass("Tool")
    if tool and TARGET_ITEM_SET[tool.Name] then found[#found+1] = tool.Name end
    return found
end

-- ── Make ESP object for a model ──────────────────────
local function makeESP(model, isPlr2, isBoss)
    if espObjs[model] then return end

    -- Cache part refs once so drawESP never calls FindFirstChild
    local head = model:FindFirstChild("Head") or model:FindFirstChild("UpperTorso")
    local skelParts = {}
    for i = 1, SKEL_N do
        skelParts[i] = {
            model:FindFirstChild(SKEL[i][1]),
            model:FindFirstChild(SKEL[i][2])
        }
    end

    local hl
    pcall(function()
        hl = Instance.new("Highlight")
        hl.FillTransparency    = isPlr2 and 0.6 or 0.75
        hl.OutlineTransparency = 0
        hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Adornee             = model
        hl.Parent              = model
    end)

    local bossCol = c3FromStr(S.ESPBossColor)
    local box     = newD("Square", {Visible=false, Filled=false, Thickness=1.5, Color=Color3.new(0,0,0)})
    local boxFill = newD("Square", {Visible=false, Filled=true,  Thickness=1,   Color=Color3.new(0,0,0), Transparency=0.85})
    local hpBg    = newD("Square", {Visible=false, Filled=true,  Thickness=1,   Color=Color3.fromRGB(20,20,20), Transparency=0.4})
    local hpBar   = newD("Square", {Visible=false, Filled=true,  Thickness=1,   Color=Color3.new(0,1,0)})
    local hpTxt   = newD("Text",   {Visible=false, Size=11, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0), Color=Color3.new(1,1,1), Font=Drawing.Fonts.Plex})
    local nameTxt = newD("Text",   {Visible=false, Size=12, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0), Font=Drawing.Fonts.Plex})
    local distTxt = newD("Text",   {Visible=false, Size=10, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0), Color=Color3.fromRGB(200,200,200), Font=Drawing.Fonts.Plex})
    local bossTag = newD("Text",   {Visible=false, Size=13, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0), Color=bossCol, Font=Drawing.Fonts.Plex, Text="[ BOSS ]"})
    local itemTxt = newD("Text",   {Visible=false, Size=11, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0), Color=Color3.fromRGB(255,215,0), Font=Drawing.Fonts.Plex})

    local skel = {}
    for i = 1, SKEL_N do
        skel[i] = newD("Line", {Visible=false, Thickness=1, Color=Color3.new(1,1,1), Transparency=0.3})
    end

    -- Per-entity state to avoid redundant property writes
    local lastHP    = -1
    local lastItems = ""
    local lastCol   = nil

    espObjs[model] = {
        hl=hl, box=box, boxFill=boxFill,
        hpBg=hpBg, hpBar=hpBar, hpTxt=hpTxt,
        nameTxt=nameTxt, distTxt=distTxt,
        bossTag=bossTag, itemTxt=itemTxt, skel=skel,
        isPlr=isPlr2, isBoss=isBoss,
        head=head, skelParts=skelParts,
        lastHP=lastHP, lastItems=lastItems, lastCol=lastCol,
        hidden=false,
    }
end

-- ── Kill ESP — clean removal ─────────────────────────
local function killESP(model)
    local d = espObjs[model]
    if not d then return end
    d.box:Remove();     d.boxFill:Remove()
    d.hpBg:Remove();   d.hpBar:Remove();   d.hpTxt:Remove()
    d.nameTxt:Remove(); d.distTxt:Remove()
    d.bossTag:Remove(); d.itemTxt:Remove()
    for i = 1, #d.skel do d.skel[i]:Remove() end
    if d.hl and typeof(d.hl) == "Instance" then
        d.hl:Destroy()
    end
    espObjs[model] = nil
end

-- ── Hide ESP — batch toggle, only writes when needed ─
local function hideESP(d)
    if d.hidden then return end
    d.hidden = true
    d.box.Visible=false;    d.boxFill.Visible=false
    d.hpBg.Visible=false;   d.hpBar.Visible=false;  d.hpTxt.Visible=false
    d.nameTxt.Visible=false; d.distTxt.Visible=false
    d.bossTag.Visible=false; d.itemTxt.Visible=false
    for i = 1, #d.skel do d.skel[i].Visible=false end
end

-- ── Draw ESP — main render, minimized property writes ─
local function drawESP(model, d, h, dist)
    local r = root(model)
    if not r then hideESP(d); return end
    d.hidden = false

    -- Color — only write when changed
    local col = espColor(d.isBoss, d.isPlr)
    if col ~= d.lastCol then
        d.lastCol = col
        if d.hl and typeof(d.hl) == "Instance" then
            d.hl.FillColor    = col
            d.hl.OutlineColor = col
        end
        d.nameTxt.Color = col
    end

    -- World → screen projection
    local rsp, ron = Camera:WorldToViewportPoint(r.Position)
    if not ron then hideESP(d); return end

    local hsp = rsp
    local head = d.head
    if head then
        local hs, ho = Camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.5,0))
        if ho then hsp = hs end
    end

    local bH = math.abs(rsp.Y - hsp.Y) * 1.1
    local bW = bH * 0.55
    local bx = rsp.X - bW * 0.5
    local by = hsp.Y - bH * 0.05
    local cx = bx + bW * 0.5

    -- Box
    if S.ESPShowBox then
        d.box.Visible=true;    d.box.Color=col
        d.box.Position=Vector2.new(bx,by); d.box.Size=Vector2.new(bW,bH)
        d.boxFill.Visible=true; d.boxFill.Color=col
        d.boxFill.Position=Vector2.new(bx,by); d.boxFill.Size=Vector2.new(bW,bH)
    else
        d.box.Visible=false; d.boxFill.Visible=false
    end

    -- Health — only recompute when HP actually changed
    if S.ESPShowHealth then
        local hp  = h.Health
        local mhp = h.MaxHealth
        if hp ~= d.lastHP then
            d.lastHP = hp
            local pct  = math.clamp(hp / mhp, 0, 1)
            local bwid = 3
            local bx2  = bx - bwid - 2
            local hcol = pct > 0.6
                and Color3.fromRGB(50,220,50)
                or  pct > 0.3
                and Color3.fromRGB(220,180,50)
                or  Color3.fromRGB(220,50,50)
            d.hpBg.Visible=true
            d.hpBg.Position=Vector2.new(bx2, by)
            d.hpBg.Size=Vector2.new(bwid, bH)
            d.hpBar.Visible=true; d.hpBar.Color=hcol
            d.hpBar.Position=Vector2.new(bx2, by + bH*(1-pct))
            d.hpBar.Size=Vector2.new(bwid, bH*pct)
            d.hpTxt.Visible=true; d.hpTxt.Color=hcol
            d.hpTxt.Position=Vector2.new(cx, by+bH+2)
            d.hpTxt.Text=string.format("%d/%d", math.floor(hp), math.floor(mhp))
        else
            -- HP unchanged — just reposition (box moved)
            local bwid = 3
            d.hpBg.Position  = Vector2.new(bx - bwid - 2, by)
            d.hpBg.Size      = Vector2.new(bwid, bH)
            local pct = math.clamp(h.Health / h.MaxHealth, 0, 1)
            d.hpBar.Position = Vector2.new(bx - bwid - 2, by + bH*(1-pct))
            d.hpBar.Size     = Vector2.new(bwid, bH*pct)
            d.hpTxt.Position = Vector2.new(cx, by+bH+2)
        end
    else
        d.hpBg.Visible=false; d.hpBar.Visible=false; d.hpTxt.Visible=false
    end

    -- Name
    local labelY = by - 14
    if S.ESPShowName then
        d.nameTxt.Visible=true
        d.nameTxt.Position=Vector2.new(cx, labelY)
        d.nameTxt.Text=model.Name
        labelY = labelY - 12
    else
        d.nameTxt.Visible=false
    end

    -- Distance
    if S.ESPShowDist then
        d.distTxt.Visible=true
        d.distTxt.Position=Vector2.new(cx, labelY)
        d.distTxt.Text=string.format("%.0fm", dist)
        labelY = labelY - 12
    else
        d.distTxt.Visible=false
    end

    -- Boss tag
    if S.ESPShowBossTag and d.isBoss then
        d.bossTag.Visible=true
        d.bossTag.Position=Vector2.new(cx, labelY)
        labelY = labelY - 14
    else
        d.bossTag.Visible=false
    end

    -- Item tracker (players only) — only recompute when backpack changes
    if d.isPlr then
        local plr = playerFromModel(model)
        if plr then
            local items    = getHeldItems(plr)
            local itemStr  = table.concat(items, ", ")
            if itemStr ~= d.lastItems then
                d.lastItems = itemStr
                if #items > 0 then
                    d.itemTxt.Visible=true
                    d.itemTxt.Text=(#items>1 and "Items: " or "Item: ") .. itemStr
                    -- green highlight for item carriers
                    if d.hl and typeof(d.hl) == "Instance" then
                        d.hl.FillColor   = Color3.fromRGB(0,255,0)
                        d.hl.OutlineColor= Color3.fromRGB(255,255,255)
                        d.hl.FillTransparency = 0.4
                    end
                else
                    d.itemTxt.Visible=false
                    -- revert highlight to normal player color
                    if d.hl and typeof(d.hl) == "Instance" then
                        d.hl.FillColor   = col
                        d.hl.OutlineColor= col
                        d.hl.FillTransparency = 0.6
                    end
                end
            end
            if d.itemTxt.Visible then
                d.itemTxt.Position=Vector2.new(cx, labelY)
            end
        else
            d.itemTxt.Visible=false
        end
    else
        d.itemTxt.Visible=false
    end

    -- Skeleton — only when enabled, uses cached part refs
    if S.ESPShowSkeleton then
        local sp = d.skelParts
        for i = 1, SKEL_N do
            local l  = d.skel[i]
            local p1 = sp[i][1]
            local p2 = sp[i][2]
            if p1 and p2 then
                local s1, o1 = Camera:WorldToViewportPoint(p1.Position)
                local s2, o2 = Camera:WorldToViewportPoint(p2.Position)
                if o1 and o2 then
                    l.Visible=true
                    l.From=Vector2.new(s1.X,s1.Y)
                    l.To=Vector2.new(s2.X,s2.Y)
                    l.Color=col
                else
                    l.Visible=false
                end
            else
                l.Visible=false
            end
        end
    else
        -- Batch hide — only writes when switching off
        if not d._skelHidden then
            d._skelHidden = true
            for i = 1, #d.skel do d.skel[i].Visible=false end
        end
    end
    if S.ESPShowSkeleton then d._skelHidden = false end
end

-- ── Player cache ─────────────────────────────────────
local function rebuildESPCache()
    espPlrCache = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then espPlrCache[p.Character] = true end
        p.CharacterAdded:Connect(function(c)
            espPlrCache[c] = true
            c.AncestryChanged:Connect(function()
                if not c:IsDescendantOf(game) then espPlrCache[c] = nil end
            end)
        end)
    end
end

